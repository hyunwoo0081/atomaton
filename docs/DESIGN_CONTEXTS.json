{
  "project_name": "atomaton",
  "architecture_pattern": "Node-based Workflow Engine (Monorepo)",
  "data_flow": {
    "entry_point": "Triggers (IMAP/Webhook)",
    "execution_id": "UUID v4",
    "context_object": "WorkflowContext",
    "variable_syntax": "{{variable_name}}"
  },
  "workflow_context_structure": {
    "workflowId": "string",
    "triggerId": "string",
    "executionId": "string",
    "data": "Record<string, unknown> (Directly accessible via {{key}})",
    "results": "Record<string, unknown> (Nested execution results from nodes)"
  },
  "node_types": {
    "triggers": [
      {
        "type": "trigger-webhook",
        "description": "Receives JSON payload via POST"
      }
    ],
    "actions": [
      {
        "type": "action",
        "label": "Discord Webhook",
        "config_fields": ["webhookUrl", "content"]
      },
      {
        "type": "action-notion",
        "label": "Notion Integration",
        "config_fields": ["databaseId", "properties"]
      },
      {
        "type": "action-http",
        "label": "Generic HTTP Request",
        "config_fields": ["method", "url", "headers", "body", "responseMapping"]
      }
    ],
    "logic": [
      {
        "type": "condition",
        "label": "Logical Condition (AND/OR)",
        "config_fields": ["logicType", "conditions"]
      }
    ]
  },
  "variable_mapping_rules": {
    "extraction_utility": "resolvePath(obj, path)",
    "merging_logic": "HTTP Node results are merged directly into currentContext.data if responseMapping is used."
  }
}
