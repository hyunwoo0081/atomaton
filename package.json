{
  "name": "atomaton",
  "private": true,
  "scripts": {
    "build": "pnpm --filter \"./apps/**\" build",
    "dev": "pnpm --parallel --filter \"./apps/**\" dev",
    "dev:api": "pnpm --filter @atomaton/api dev",
    "dev:web": "pnpm --filter @atomaton/web dev",
    "build:api": "pnpm --filter @atomaton/api build",
    "build:web": "pnpm --filter @atomaton/web build",
    "lint": "pnpm --filter \"./**\" lint",
    "test": "pnpm --filter \"./**\" test",
    "test:e2e": "pnpm --filter @atomaton/web test:e2e",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@8.15.5",
  "pnpm": {
    "overrides": {
      "follow-redirects": ">=1.16.0",
      "semver": ">=7.7.1",
      "minimatch": ">=9.0.7",
      "postcss": ">=8.5.10",
      "rollup": ">=4.59.0"
    }
  }
}
